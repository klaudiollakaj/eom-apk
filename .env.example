# Database
DATABASE_URL=postgresql://eom:eom@localhost:5432/eom

# Auth
BETTER_AUTH_SECRET=change-me-to-a-random-string
BETTER_AUTH_URL=http://localhost:3000

# Email verification (set to "true" to require, omit or "false" to skip)
REQUIRE_EMAIL_VERIFICATION=false

# Seeder (CI/CD only — never commit values)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Email (optional — if not set, emails are skipped)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@eom.local

# UploadThing (file uploads — profile images, service photos, etc.)
UPLOADTHING_TOKEN=

# Ticketing — HMAC secret for signing ticket QR code JWTs (generate a random value)
TICKET_SIGNING_SECRET=

# Stripe (optional — if not set, checkout falls back to the mock payment form)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# App URL — used in email deep links (e.g., https://eom.example.com)
APP_URL=
